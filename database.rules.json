{
  "rules": {
    "matches": {
      ".indexOn": ["createdAt"],
      "$matchId": {
        ".read": "auth != null",
        ".write": "auth != null",
        "presence": {
          "$uid": {
            ".write": "auth != null && auth.uid === $uid"
          }
        }
      }
    },
    "publicQueue": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid"
      }
    }
  }
}